# --- PartnerOS by Watty — environment configuration ---

# Data source: "mock" (default — in-memory demo dataset, no external calls) or "db"
DATA_SOURCE=mock

# Postgres (used when DATA_SOURCE=db and Prisma is wired up — see prisma/schema.prisma)
DATABASE_URL="postgresql://partneros:partneros@localhost:5432/partneros?schema=public"

# AI Partner Assistant — used ONLY for summaries, explanations, recommendations and drafting.
# The MVP ships a deterministic template engine (src/lib/ai.ts); set a key to swap in a real model.
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6
# OPENAI_API_KEY=

# Map tiles (optional — site detail pages show schematic placeholders without it)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Email (optional — partner communications / report delivery)
SMTP_URL=
