# --- VoltYield environment configuration ---

# Data source mode: "mock" (default, no external calls) or "live"
DATA_SOURCE=mock

# Postgres connection string (used when DATA_SOURCE=live and Prisma is wired up)
DATABASE_URL="postgresql://voltyield:voltyield@localhost:5432/voltyield?schema=public"

# External data providers (optional, only used in live mode)
OPENCHARGEMAP_API_KEY=
GOOGLE_MAPS_API_KEY=
CHARGEPRICE_API_KEY=

# Weather / demand signals (optional)
OPENWEATHER_API_KEY=

# LLM provider for recommendation explanations (optional — engine works without it)
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# Map tiles (optional — UI degrades to schematic map without it)
NEXT_PUBLIC_MAPBOX_TOKEN=
